@model QuanLyKho.Models.ApplicationUser

@{
    ViewData["Title"] = "Sửa phân quyền";
    Layout = "_AdminlteNetcore";
    
    // Map tên Role (property) -> tên hiển thị tiếng Việt
    var roleDisplayNames = new Dictionary<string, string>
    {
        { "TransferOrderRole", "Phiếu chuyển kho" },
        { "WarehouseRole", "Kho hàng" },
        { "ApplicationUserRole", "Quản lý người dùng" },
        { "HomeRole", "Trang chủ" },
        { "BranchRole", "Chi nhánh" },
        { "CustomerRole", "Khách hàng" },
        { "ProductRole", "Sản phẩm" },
        { "PurchaseOrderRole", "Đơn mua hàng" },
        { "ReceivingRole", "Nhập hàng" },
        { "SalesOrderRole", "Đơn bán hàng" },
        { "ShipmentRole", "Giao hàng" },
        { "StockRole", "Tồn kho" },
        { "TransferInRole", "Chuyển kho" },
        { "TransferOutRole", "Xuất chuyển kho" },
        { "VendorRole", "Nhà cung cấp" }
    };
}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <form asp-action="Edit">
        <section class="content">
            <!-- Default box -->
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">Phân quyền</h3>
                    <div class="box-tools pull-right">
                        <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip"
                                title="Thu gọn">
                            <i class="fa fa-minus"></i>
                        </button>
                        <button type="button" class="btn btn-box-tool" data-widget="remove" data-toggle="tooltip" title="Đóng">
                            <i class="fa fa-times"></i>
                        </button>
                    </div>
                </div>
                <div class="box-body">
                    <div class="row">
                        <div class="col-md-12">

                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="form-group hidden">
                                <div class="checkbox">
                                    <label>
                                        <input asp-for="isSuperAdmin" /> @Html.DisplayNameFor(model => model.isSuperAdmin)
                                    </label>
                                </div>
                            </div>
                            @{ 
                                Type t = Model.GetType();
                                foreach (System.Reflection.PropertyInfo item in t.GetProperties())
                                {
                                    if (item.Name.Contains("Role") && !item.Name.Contains("Line"))
                                    {
                                        bool vlue = false;
                                        vlue = (bool)item.GetValue(Model, null);
                                        
                                        var vnName = roleDisplayNames.ContainsKey(item.Name)
                                            ? roleDisplayNames[item.Name]
                                            : item.Name;

                                         <div class="form-group">
                                            <div class="checkbox">
                                                <label>
                                                    @Html.CheckBox(item.Name, vlue) @vnName
                                                </label>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            
                          
                            <input type="hidden" asp-for="Id" />
                            <div class="form-group hidden">
                                <label asp-for="UserName" class="control-label"></label>
                                <input asp-for="UserName" class="form-control" />
                                <span asp-validation-for="UserName" class="text-danger"></span>
                            </div>
                            <!-- Hidden fields preserved -->
                            <div class="form-group hidden">
                                <label asp-for="NormalizedUserName" class="control-label"></label>
                                <input asp-for="NormalizedUserName" class="form-control" />
                                <span asp-validation-for="NormalizedUserName" class="text-danger"></span>
                            </div>
                            <div class="form-group hidden">
                                <label asp-for="Email" class="control-label"></label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="form-group hidden">
                                <label asp-for="NormalizedEmail" class="control-label"></label>
                                <input asp-for="NormalizedEmail" class="form-control" />
                                <span asp-validation-for="NormalizedEmail" class="text-danger"></span>
                            </div>
                            <div class="form-group hidden">
                                <div class="checkbox">
                                    <label>
                                        <input asp-for="EmailConfirmed" /> @Html.DisplayNameFor(model => model.EmailConfirmed)
                                    </label>
                                </div>
                            </div>
                            <div class="form-group hidden">
                                <label asp-for="PasswordHash" class="control-label"></label>
                                <input asp-for="PasswordHash" class="form-control" />
                                <span asp-validation-for="PasswordHash" class="text-danger"></span>
                            </div>
                            <div class="form-group hidden">
                                <label asp-for="SecurityStamp" class="control-label"></label>
                                <input asp-for="SecurityStamp" class="form-control" />
                                <span asp-validation-for="SecurityStamp" class="text-danger"></span>
                            </div>
                            <div class="form-group hidden">
                                <label asp-for="ConcurrencyStamp" class="control-label"></label>
                                <input asp-for="ConcurrencyStamp" class="form-control" />
                                <span asp-validation-for="ConcurrencyStamp" class="text-danger"></span>
                            </div>
                             <div class="form-group hidden">
                                <label asp-for="PhoneNumber" class="control-label"></label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="form-group hidden">
                                <div class="checkbox">
                                    <label>
                                        <input asp-for="PhoneNumberConfirmed" /> @Html.DisplayNameFor(model => model.PhoneNumberConfirmed)
                                    </label>
                                </div>
                            </div>
                            <div class="form-group hidden">
                                <div class="checkbox">
                                    <label>
                                        <input asp-for="TwoFactorEnabled" /> @Html.DisplayNameFor(model => model.TwoFactorEnabled)
                                    </label>
                                </div>
                            </div>
                            <div class="form-group hidden">
                                <label asp-for="LockoutEnd" class="control-label"></label>
                                <input asp-for="LockoutEnd" class="form-control" />
                                <span asp-validation-for="LockoutEnd" class="text-danger"></span>
                            </div>
                            <div class="form-group hidden">
                                <div class="checkbox">
                                    <label>
                                        <input asp-for="LockoutEnabled" /> @Html.DisplayNameFor(model => model.LockoutEnabled)
                                    </label>
                                </div>
                            </div>
                            <div class="form-group hidden">
                                <label asp-for="AccessFailedCount" class="control-label"></label>
                                <input asp-for="AccessFailedCount" class="form-control" />
                                <span asp-validation-for="AccessFailedCount" class="text-danger"></span>
                            </div>

                        </div>
                    </div>
                </div>
                <!-- /.box-body -->
                <div class="box-footer">
                    <div class="form-group">
                        <input type="submit" value="Lưu" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-default">Trở lại danh sách</a>
                    </div>
                </div>
                <!-- /.box-footer-->
            </div>
            <!-- /.box -->
        </section>
        <!-- /.content -->
    </form>
</div>
<!-- /.content-wrapper -->

@section Styles{
}

@section Scripts{
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
