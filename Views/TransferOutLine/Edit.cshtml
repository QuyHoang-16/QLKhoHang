@model NetCore_Update.Models.Invent.TransferOutLine

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_AdminlteNetcoreEdit.cshtml";
    }

<div class="row">
    <div class="col-md-12">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="transferOutLineId" />

        <div class="form-group hidden">
            <label class="control-label">Mã phiếu xuất điều chuyển</label>
            <select asp-for="transferOutId" class="form-control select2" asp-items="ViewBag.transferOutId"></select>
            <span asp-validation-for="transferOutId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Sản phẩm</label>
            <select asp-for="productId" class="form-control select2" asp-items="ViewBag.productId"></select>
            <span asp-validation-for="productId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Số lượng xuất</label>
            <input asp-for="qty" class="form-control" />
            <span asp-validation-for="qty" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Tồn kho</label>
            <input asp-for="qtyInventory" class="form-control" />
            <span asp-validation-for="qtyInventory" class="text-danger"></span>
        </div>
    </div>
</div>







            @section Scripts {
                 @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
            }



