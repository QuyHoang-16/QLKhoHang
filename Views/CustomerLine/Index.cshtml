@model IEnumerable<NetCore_Update.Models.Invent.CustomerLine>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminlteNetcoreIndex.cshtml";
}


<table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>Chức vụ</th>
            <th>Tên</th>
            <th>Họ</th>
            <th>Tên đệm</th>
            <th>Tên gọi khác</th>
            <th>Giới tính</th>
            <th>Xưng hô</th>
            <th>Điện thoại di động</th>
            <th>Điện thoại văn phòng</th>
            <th>Fax</th>
            <th>Email cá nhân</th>
            <th>Email công ty</th>
            <th>Khách hàng</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.jobTitle)</td>
                <td>@Html.DisplayFor(modelItem => item.firstName)</td>
                <td>@Html.DisplayFor(modelItem => item.lastName)</td>
                <td>@Html.DisplayFor(modelItem => item.middleName)</td>
                <td>@Html.DisplayFor(modelItem => item.nickName)</td>
                <td>@Html.DisplayFor(modelItem => item.gender)</td>
                <td>@Html.DisplayFor(modelItem => item.salutation)</td>
                <td>@Html.DisplayFor(modelItem => item.mobilePhone)</td>
                <td>@Html.DisplayFor(modelItem => item.officePhone)</td>
                <td>@Html.DisplayFor(modelItem => item.fax)</td>
                <td>@Html.DisplayFor(modelItem => item.personalEmail)</td>
                <td>@Html.DisplayFor(modelItem => item.workEmail)</td>

                <!-- Hiển thị tên khách hàng -->
                <td>@Html.DisplayFor(modelItem => item.customer.customerName)</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.customerLineId" title="Chỉnh sửa"><i class="fa fa-pencil"></i></a> |
                    <a asp-action="Details" asp-route-id="@item.customerLineId" title="Chi tiết"><i class="fa fa-list"></i></a> |
                    <a asp-action="Delete" asp-route-id="@item.customerLineId" title="Xóa" onclick="return confirm('Bạn có chắc muốn xóa không?')">
                        <i class="fa fa-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
