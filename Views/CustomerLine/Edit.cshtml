@model NetCore_Update.Models.Invent.CustomerLine

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_AdminlteNetcoreEdit.cshtml";
    }


<div class="row">
    <div class="col-md-12">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="customerLineId" />

        <div class="form-group">
            <label class="control-label">Chức vụ</label>
            <input asp-for="jobTitle" class="form-control" />
            <span asp-validation-for="jobTitle" class="text-danger"></span>
        </div>

        <div class="form-group hidden">
            <label class="control-label">Khách hàng</label>
            <select asp-for="customerId" class="form-control select2" asp-items="ViewBag.customerId"></select>
            <span asp-validation-for="customerId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Tên</label>
            <input asp-for="firstName" class="form-control" />
            <span asp-validation-for="firstName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Họ</label>
            <input asp-for="lastName" class="form-control" />
            <span asp-validation-for="lastName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Tên đệm</label>
            <input asp-for="middleName" class="form-control" />
            <span asp-validation-for="middleName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Tên gọi khác</label>
            <input asp-for="nickName" class="form-control" />
            <span asp-validation-for="nickName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Giới tính</label>
            <select asp-for="gender" class="form-control select2" asp-items="Html.GetEnumSelectList<NetCore_Update.Models.Invent.Gender>()"></select>
            <span asp-validation-for="gender" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Xưng hô</label>
            <select asp-for="salutation" class="form-control select2" asp-items="Html.GetEnumSelectList<NetCore_Update.Models.Invent.Salutation>()"></select>
            <span asp-validation-for="salutation" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Điện thoại di động</label>
            <input asp-for="mobilePhone" class="form-control" />
            <span asp-validation-for="mobilePhone" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Điện thoại văn phòng</label>
            <input asp-for="officePhone" class="form-control" />
            <span asp-validation-for="officePhone" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Fax</label>
            <input asp-for="fax" class="form-control" />
            <span asp-validation-for="fax" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Email cá nhân</label>
            <input asp-for="personalEmail" class="form-control" />
            <span asp-validation-for="personalEmail" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Email công ty</label>
            <input asp-for="workEmail" class="form-control" />
            <span asp-validation-for="workEmail" class="text-danger"></span>
        </div>
    </div>
</div>







            @section Scripts {
                 @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
            }



