@model QuanLyKho.Models.Invent.CustomerLine

@{
    ViewData["Title"] = "Chi tiết";
    Layout = "~/Views/Shared/_AdminlteNetcoreDetails.cshtml";
}



<div class="row">
    <div class="col-md-9">
        <!-- Default box -->
        <div class="box box-primary">
            <div class="box-body">
                <div>
                    <dl class="dl-horizontal">
                        <dt>Chức vụ</dt>
                        <dd>@Html.DisplayFor(model => model.jobTitle)</dd>

                        <dt>Tên</dt>
                        <dd>@Html.DisplayFor(model => model.firstName)</dd>

                        <dt>Họ</dt>
                        <dd>@Html.DisplayFor(model => model.lastName)</dd>

                        <dt>Tên đệm</dt>
                        <dd>@Html.DisplayFor(model => model.middleName)</dd>

                        <dt>Tên gọi khác</dt>
                        <dd>@Html.DisplayFor(model => model.nickName)</dd>

                        <dt>Giới tính</dt>
                        <dd>@Html.DisplayFor(model => model.gender)</dd>

                        <dt>Xưng hô</dt>
                        <dd>@Html.DisplayFor(model => model.salutation)</dd>

                        <dt>Điện thoại di động</dt>
                        <dd>@Html.DisplayFor(model => model.mobilePhone)</dd>

                        <dt>Điện thoại văn phòng</dt>
                        <dd>@Html.DisplayFor(model => model.officePhone)</dd>

                        <dt>Fax</dt>
                        <dd>@Html.DisplayFor(model => model.fax)</dd>

                        <dt>Email cá nhân</dt>
                        <dd>@Html.DisplayFor(model => model.personalEmail)</dd>

                        <dt>Email công ty</dt>
                        <dd>@Html.DisplayFor(model => model.workEmail)</dd>

                        <dt>Ngày tạo</dt>
                        <dd>@Html.DisplayFor(model => model.createdAt)</dd>

                        <dt>Khách hàng</dt>
                        <dd>@Html.DisplayFor(model => model.customer.customerName)</dd>
                    </dl>
                </div>
            </div>
            <!-- /.box-body -->
            <div class="box-footer">
                <div class="form-group">
                    <a asp-action="Edit" asp-route-id="@Model.customerLineId" class="btn btn-primary">Sửa</a>
                    <a asp-action="Index" class="btn btn-default">Trở lại danh sách</a>
                </div>
            </div>
            <!-- /.box-footer-->
        </div>
        <!-- /.box -->
    </div>
    <div class="col-md-3">
    </div>
</div>




