@model QuanLyKho.Models.Invent.SalesOrderLine


@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_AdminlteNetcorePopup.cshtml";
}


<div class="row">
    <div class="col-md-12">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="salesOrderLineId" />

        <div class="form-group hidden">
            <label>Đơn bán hàng</label>
            <select asp-for="salesOrderId" class="form-control select2" asp-items="ViewBag.salesOrderId"></select>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label>Sản phẩm</label>
                    <select asp-for="productId" class="form-control select2" asp-items="ViewBag.productId"></select>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    <label>Số lượng</label>
                    <input asp-for="qty" class="form-control" />
                    <span asp-validation-for="qty" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label>Đơn giá</label>
                    <input asp-for="price" class="form-control" />
                    <span asp-validation-for="price" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    <label>Tiền giảm giá</label>
                    <input asp-for="discountAmount" class="form-control" />
                    <span asp-validation-for="discountAmount" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group hidden">
            <label>Thành tiền</label>
            <input asp-for="totalAmount" class="form-control" />
            <span asp-validation-for="totalAmount" class="text-danger"></span>
        </div>

    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
