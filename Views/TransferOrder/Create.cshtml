@model QuanLyKho.Models.Invent.TransferOrder


@{
    ViewData["Title"] = "Tạo mới lệnh điều chuyển";
    Layout = "~/Views/Shared/_AdminlteNetcoreCreate.cshtml";
    ViewData["EntityIcon"] = "fa fa-recycle";
    ViewData["HeaderText"] = "Tạo mới lệnh điều chuyển";
    ViewData["CreateInfo"] = "Lệnh điều chuyển (TO) là quy trình chuyển sản phẩm từ kho này sang kho khác. Kho đi và Kho đến phải khác nhau.";
}

<partial name="_StatusMessage" model="@ViewBag.StatusMessage" />
<div class="row">
    <div class="col-md-12">
        <partial name="_StatusMessage" model="@ViewBag.StatusMessage" />
        <div asp-validation-summary="All" class="text-danger"></div>

        <input type="hidden" asp-for="transferOrderStatus" />
        <input type="hidden" asp-for="transferOrderNumber" />

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Mã phiếu điều chuyển</label>
                    <input asp-for="transferOrderNumber" class="form-control" disabled />
                    <span asp-validation-for="transferOrderNumber" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Ngày lập phiếu</label>
                    <div class="input-group date">
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                        <input asp-for="transferOrderDate" value="@Model.transferOrderDate.ToString("MM/dd/yyyy")" class="form-control pull-right datepicker" type="text" />
                    </div>
                    <span asp-validation-for="transferOrderDate" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label class="control-label">Mô tả</label>
            <input asp-for="description" class="form-control" />
            <span asp-validation-for="description" class="text-danger"></span>
        </div>


        <div class="row hidden">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Chi nhánh chuyển</label>
                    <select asp-for="branchIdFrom" class="form-control select2" asp-items="ViewBag.branchIdFrom"></select>
                    <span asp-validation-for="branchIdFrom" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Chi nhánh nhận</label>
                    <select asp-for="branchIdTo" class="form-control select2" asp-items="ViewBag.branchIdTo"></select>
                    <span asp-validation-for="branchIdTo" class="text-danger"></span>
                </div>
            </div>
        </div>


        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Kho chuyển</label>
                    <select asp-for="warehouseIdFrom" class="form-control select2" asp-items="ViewBag.warehouseIdFrom"></select>
                    <span asp-validation-for="warehouseIdFrom" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Kho nhận</label>
                    <select asp-for="warehouseIdTo" class="form-control select2" asp-items="ViewBag.warehouseIdTo"></select>
                    <span asp-validation-for="warehouseIdTo" class="text-danger"></span>
                </div>
            </div>
        </div>


        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Người phụ trách</label>
                    <input asp-for="picName" class="form-control" />
                    <span asp-validation-for="picName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Trạng thái phiếu</label>
                    <select asp-for="transferOrderStatus" class="form-control select2" asp-items="Html.GetEnumSelectList<QuanLyKho.Models.Invent.TransferOrderStatus>()" disabled></select>
                    <span asp-validation-for="transferOrderStatus" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

