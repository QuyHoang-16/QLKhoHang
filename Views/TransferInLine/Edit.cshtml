@model QuanLyKho.Models.Invent.TransferInLine

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_AdminlteNetcoreEdit.cshtml";
    }


<div class="row">
    <div class="col-md-12">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="transferInLineId" />

        <div class="form-group hidden">
            <label for="transferInId">Phiếu nhập điều chuyển</label>
            <select asp-for="transferInId" class="form-control select2" asp-items="ViewBag.transferInId"></select>
            <span asp-validation-for="transferInId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="productId">Sản phẩm</label>
            <select asp-for="productId" class="form-control select2" asp-items="ViewBag.productId"></select>
            <span asp-validation-for="productId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="qty">Số lượng nhập</label>
            <input asp-for="qty" class="form-control" />
            <span asp-validation-for="qty" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="qtyInventory">Tồn kho sau nhập</label>
            <input asp-for="qtyInventory" class="form-control" />
            <span asp-validation-for="qtyInventory" class="text-danger"></span>
        </div>
    </div>
</div>

            @section Scripts {
                 @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
            }



