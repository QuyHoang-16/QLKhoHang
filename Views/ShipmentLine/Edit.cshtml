@model QuanLyKho.Models.Invent.ShipmentLine

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_AdminlteNetcoreEdit.cshtml";
    }


<div class="row">
    <div class="col-md-12">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="shipmentLineId" />

        <div class="form-group hidden">
            <label class="control-label">Mã phiếu giao hàng</label>
            <select asp-for="shipmentId" class="form-control select2" asp-items="ViewBag.shipmentId"></select>
            <span asp-validation-for="shipmentId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Chi nhánh</label>
            <select asp-for="branchId" class="form-control select2" asp-items="ViewBag.branchId"></select>
            <span asp-validation-for="branchId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Kho</label>
            <select asp-for="warehouseId" class="form-control select2" asp-items="ViewBag.warehouseId"></select>
            <span asp-validation-for="warehouseId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Sản phẩm</label>
            <select asp-for="productId" class="form-control select2" asp-items="ViewBag.productId"></select>
            <span asp-validation-for="productId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Số lượng yêu cầu</label>
            <input asp-for="qty" class="form-control" />
            <span asp-validation-for="qty" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Số lượng giao</label>
            <input asp-for="qtyShipment" class="form-control" />
            <span asp-validation-for="qtyShipment" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Số lượng tồn kho</label>
            <input asp-for="qtyInventory" class="form-control" />
            <span asp-validation-for="qtyInventory" class="text-danger"></span>
        </div>
    </div>
</div>

           @section Scripts {
                 @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
            }



