@model NetCore_Update.Models.Invent.PurchaseOrder
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>In Đơn Đặt Hàng</title>
</head>
<body onload="window.print();">
    <div class="wrapper">
        <!-- Main content -->
        <section class="invoice">

            <!-- title row -->
            <div class="row">
                <div class="col-xs-12">
                    <h2 class="page-header">
                        <i class="fa fa-globe"></i> ĐƠN ĐẶT HÀNG (PURCHASE ORDER)
                        <small class="pull-right">Số: @Model.purchaseOrderNumber</small>
                    </h2>
                </div>
            </div>

            <!-- info row -->
            <div class="row invoice-info">
                <div class="col-sm-4 invoice-col">
                    Nhà cung cấp
                    <address>
                        <strong>@Model.vendor.vendorName</strong><br>
                        @Model.vendor.street1<br>
                        @Model.vendor.street2<br>
                        @Model.vendor.city<br>
                        Người liên hệ: @Model.picVendor
                    </address>
                </div>

                <div class="col-sm-4 invoice-col">
                    Địa chỉ giao hàng
                    <address>
                        <strong>@Model.branch.branchName</strong><br>
                        @Model.branch.street1<br>
                        @Model.branch.street2<br>
                        @Model.branch.city<br>
                        Người phụ trách: @Model.picInternal <br />
                        @Model.deliveryAddress<br>
                    </address>
                </div>

                <div class="col-sm-4 invoice-col">
                    <b>Số PO:</b> @Model.purchaseOrderNumber<br>
                    <b>Ngày PO:</b> @Model.poDate.ToString("dd-MM-yyyy")<br>
                    <b>Ngày giao dự kiến:</b> @Model.deliveryDate.ToString("dd-MM-yyyy")<br>
                </div>
            </div>

            <!-- items -->
            <div class="row">
                <div class="col-xs-12 table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Số lượng</th>
                                <th>Mã sản phẩm</th>
                                <th>Giá</th>
                                <th>Mô tả sản phẩm</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.purchaseOrderLine)
                            {
                                <tr>
                                    <td>@item.qty</td>
                                    <td>@item.product.productCode</td>
                                    <td>@item.price.ToString()</td>
                                    <td>@item.product.productName</td>
                                    <td>@item.totalAmount.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- description + totals -->
            <div class="row">
                <div class="col-xs-6">
                    <p class="lead">Ghi chú:</p>
                    <p class="text-muted well well-sm no-shadow" style="margin-top: 10px;">
                        @Model.description
                    </p>
                </div>

                <div class="col-xs-6">
                    <p class="lead">Chi tiết thanh toán</p>
                    <div class="table-responsive">
                        <table class="table">
                            <tr>
                                <th style="width:50%">Tạm tính:</th>
                                <td>@Model.totalOrderAmount.ToString("C")</td>
                            </tr>
                            <tr>
                                <th>Giảm giá:</th>
                                <td>@Model.totalDiscountAmount.ToString("C")</td>
                            </tr>
                            <tr>
                                <th>Tổng cộng:</th>
                                <td>
                                    @((Model.totalOrderAmount - Model.totalDiscountAmount).ToString("C"))
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

        </section>
    </div>

    @Html.Partial("_AdminlteNetcoreBasicStyles")
    @Html.Partial("_AdminlteNetcoreBasicScripts")
</body>
</html>
