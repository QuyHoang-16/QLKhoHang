@model QuanLyKho.Models.Invent.PurchaseOrder

@{
    Layout = "_AdminlteNetcore";
}

<!-- Content Wrapper. Contains page content -->
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <h1>
            Đơn Đặt Hàng (Purchase Order)
            <small>@Model.purchaseOrderNumber</small>
        </h1>
    </section>

    <div class="pad margin no-print">
        <div class="callout callout-info" style="margin-bottom: 0!important;">
            <h4><i class="fa fa-info"></i> Thông báo:</h4>
            Trang này đã được tối ưu để in. Nhấn nút "In" bên dưới để in tài liệu.
        </div>
    </div>

    <!-- Main content -->
    <section class="invoice">

        <!-- title row -->
        <div class="row">
            <div class="col-xs-12">
                <h2 class="page-header">
                    <i class="fa fa-globe"></i> Đơn Đặt Hàng
                    <small class="pull-right">Ngày: @Model.poDate.ToString("dd-MM-yyyy")</small>
                </h2>
            </div>
        </div>

        <!-- info row -->
        <div class="row invoice-info">
            <div class="col-sm-4 invoice-col">
                Nhà cung cấp
                <address>
                    <strong>@Model.vendor.vendorName</strong><br />
                    @Model.vendor.street1<br />
                    @Model.vendor.street2<br />
                    @Model.vendor.city<br />
                    Người liên hệ: @Model.picVendor
                </address>
            </div>

            <div class="col-sm-4 invoice-col">
                Địa chỉ giao hàng
                <address>
                    <strong>@Model.branch.branchName</strong><br />
                    @Model.branch.street1<br />
                    @Model.branch.street2<br />
                    @Model.branch.city<br />
                    Người phụ trách: @Model.picInternal<br />
                    @Model.deliveryAddress
                </address>
            </div>

            <div class="col-sm-4 invoice-col">
                <b>Số PO:</b> @Model.purchaseOrderNumber<br />
                <b>Ngày PO:</b> @Model.poDate.ToString("dd-MM-yyyy")<br />
                <b>Ngày giao dự kiến:</b> @Model.deliveryDate.ToString("dd-MM-yyyy")<br />
            </div>
        </div>

        <!-- Table row -->
        <div class="row">
            <div class="col-xs-12 table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Số lượng</th>
                            <th>Mã sản phẩm</th>
                            <th>Giá</th>
                            <th>Mô tả</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.purchaseOrderLine)
                        {
                            <tr>
                                <td>@item.qty</td>
                                <td>@item.product.productCode</td>
                                <td>@item.price.ToString()</td>
                                <td>@item.product.productName</td>
                                <td>@item.totalAmount.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Description + totals -->
        <div class="row">
            <div class="col-xs-6">
                <p class="lead">Ghi chú:</p>
                <p class="text-muted well well-sm no-shadow" style="margin-top: 10px;">
                    @Model.description
                </p>
            </div>

            <div class="col-xs-6">
                <p class="lead">Chi tiết thanh toán</p>
                <div class="table-responsive">
                    <table class="table">
                        <tr>
                            <th style="width:50%">Tạm tính:</th>
                            <td>@Model.totalOrderAmount.ToString("C")</td>
                        </tr>
                        <tr>
                            <th>Giảm giá:</th>
                            <td>@Model.totalDiscountAmount.ToString("C")</td>
                        </tr>
                        <tr>
                            <th>Tổng cộng:</th>
                            <td>@((Model.totalOrderAmount - Model.totalDiscountAmount).ToString("C"))</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Print button -->
        <div class="row no-print">
            <div class="col-xs-12">
                <a href="@Url.Action("PrintPurchaseOrder", new { id = Model.purchaseOrderId })" target="_blank" class="btn btn-primary">
                    <i class="fa fa-print"></i> In
                </a>
            </div>
        </div>

    </section>
    <div class="clearfix"></div>
</div>
