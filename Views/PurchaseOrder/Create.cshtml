@model QuanLyKho.Models.Invent.PurchaseOrder


@{
    ViewData["Title"] = "Tạo mới đơn mua hàng";
    Layout = "~/Views/Shared/_AdminlteNetcoreCreate.cshtml";
    ViewData["EntityIcon"] = "fa fa-file-text";
    ViewData["HeaderText"] = "Tạo mới đơn mua hàng";
    ViewData["CreateInfo"] = "Đơn mua hàng (PO) là chứng từ thương mại do công ty bạn phát hành với tư cách là người mua gửi cho nhà cung cấp với tư cách là người bán sản phẩm." +
            " Có ba trạng thái của PO: 1. Nháp (PO chưa được xác nhận, chưa sẵn sàng để nhập kho), 2. Mở (PO đã được xác nhận, sẵn sàng để nhập kho) và 3. Hoàn thành (PO đã đóng, đã nhận đủ hàng).";
}


<div class="row">
    <div class="col-md-12">
        @Html.Partial("_StatusMessage", (string)ViewBag.StatusMessage)
        <div asp-validation-summary="All" class="text-danger"></div>
        <input type="hidden" asp-for="purchaseOrderNumber" />
        <input type="hidden" asp-for="purchaseOrderStatus" />

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label class="control-label">Mã đơn mua hàng</label>
                    <input asp-for="purchaseOrderNumber" class="form-control" disabled />
                    <span asp-validation-for="purchaseOrderNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="form-group">
                    <label class="control-label">Điều khoản thanh toán (TOP)</label>
                    <select asp-for="top" class="form-control select2" asp-items="Html.GetEnumSelectList<QuanLyKho.Models.Invent.TOP>()"></select>
                    <span asp-validation-for="top" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="form-group">
                    <label class="control-label">Chi nhánh</label>
                    <select asp-for="branchId" class="form-control select2" asp-items="ViewBag.branchId"></select>
                    <span asp-validation-for="branchId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label class="control-label">Ngày đặt hàng</label>
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        <input asp-for="poDate" value="@Model.poDate.ToString("MM/dd/yyyy")" class="form-control pull-right datepicker" type="text" />
                    </div>
                    <span asp-validation-for="poDate" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="form-group">
                    <label class="control-label">Ngày giao hàng dự kiến</label>
                    <div class="input-group date">
                        <div class="input-group-addon"><i class="fa fa-calendar"></i></div>
                        <input asp-for="deliveryDate" value="@Model.deliveryDate.ToString("MM/dd/yyyy")" class="form-control pull-right datepicker" type="text" />
                    </div>
                    <span asp-validation-for="deliveryDate" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="form-group">
                    <label class="control-label">Nhà cung cấp</label>
                    <select asp-for="vendorId" class="form-control select2" asp-items="ViewBag.vendorId"></select>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Trạng thái đơn hàng</label>
                    <select asp-for="purchaseOrderStatus" class="form-control select2" asp-items="Html.GetEnumSelectList<QuanLyKho.Models.Invent.PurchaseOrderStatus>()" disabled></select>
                    <span asp-validation-for="purchaseOrderStatus" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Mô tả</label>
                    <input asp-for="description" class="form-control" />
                    <span asp-validation-for="description" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label class="control-label">Địa chỉ giao hàng</label>
            <input asp-for="deliveryAddress" class="form-control" />
            <span asp-validation-for="deliveryAddress" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Số tham chiếu nội bộ</label>
                    <input asp-for="referenceNumberInternal" class="form-control" />
                    <span asp-validation-for="referenceNumberInternal" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Số tham chiếu từ NCC</label>
                    <input asp-for="referenceNumberExternal" class="form-control" />
                    <span asp-validation-for="referenceNumberExternal" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Phụ trách nội bộ</label>
                    <input asp-for="picInternal" class="form-control" />
                    <span asp-validation-for="picInternal" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    <label class="control-label">Liên hệ nhà cung cấp</label>
                    <input asp-for="picVendor" class="form-control" />
                    <span asp-validation-for="picVendor" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Hidden -->
        <div class="form-group hidden">
            <label>Tổng chiết khấu</label>
            <input asp-for="totalDiscountAmount" class="form-control" />
        </div>

        <div class="form-group hidden">
            <label>Tổng giá trị đơn hàng</label>
            <input asp-for="totalOrderAmount" class="form-control" />
        </div>

        <div class="form-group hidden">
            <label>Số phiếu nhập hàng</label>
            <input asp-for="purchaseReceiveNumber" class="form-control" />
        </div>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

