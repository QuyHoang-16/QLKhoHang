@model NetCore_Update.Models.Invent.Vendor
@inject NetCore_Update.Data.ApplicationDbContext _context;

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_AdminlteNetcoreDelete.cshtml";
    ViewData["EntityIcon"] = "fa fa-industry";
    ViewData["DeleteInfo"] = "Vendor that already have transactions (PO) can not be deleted.";
    NetCore_Update.Models.Invent.PurchaseOrder purchaseOrder = _context.PurchaseOrders.Where(x => x.vendorId.Equals(Model.vendorId)).FirstOrDefault();
    ViewData["IsCanDeleted"] = false;
    if (purchaseOrder == null)
    {
        ViewData["IsCanDeleted"] = true;
    }
}


@Html.Partial("_StatusMessage", (string)ViewBag.StatusMessage)
<div>

    <dl class="dl-horizontal">

        <dt>Tên nhà cung cấp</dt>
        <dd>@Html.DisplayFor(model => model.vendorName)</dd>

        <dt>Mô tả</dt>
        <dd>@Html.DisplayFor(model => model.description)</dd>

        <dt>Quy mô doanh nghiệp</dt>
        <dd>@Html.DisplayFor(model => model.size)</dd>

        <dt>Địa chỉ 1</dt>
        <dd>@Html.DisplayFor(model => model.street1)</dd>

        <dt>Địa chỉ 2</dt>
        <dd>@Html.DisplayFor(model => model.street2)</dd>

        <dt>Thành phố</dt>
        <dd>@Html.DisplayFor(model => model.city)</dd>

        <dt>Tỉnh / Quận</dt>
        <dd>@Html.DisplayFor(model => model.province)</dd>

        <dt>Quốc gia</dt>
        <dd>@Html.DisplayFor(model => model.country)</dd>

        <dt>Ngày tạo</dt>
        <dd>@Html.DisplayFor(model => model.createdAt)</dd>

    </dl>

</div>
