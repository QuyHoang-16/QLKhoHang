@model QuanLyKho.Models.Invent.TransferOut

@{
    ViewData["Title"] = "Xóa";
    Layout = "~/Views/Shared/_AdminlteNetcoreDelete.cshtml";
    ViewData["EntityIcon"] = "fa fa-upload";
    ViewData["DeleteInfo"] = "Deleting goods issue will rollback the status of transfer order into [Open]. But this process can only happen if goods receive already deleted first.";
}


@Html.Partial("_StatusMessage", (string)ViewBag.StatusMessage)
<div>

    <dl class="dl-horizontal">
        <dt>
            Mã phiếu xuất điều chuyển
        </dt>
        <dd>
            @Html.DisplayFor(model => model.transferOutNumber)
        </dd>

        <dt>
            Ngày xuất kho
        </dt>
        <dd>
            @Html.DisplayFor(model => model.transferOutDate)
        </dd>

        <dt>
            Ghi chú
        </dt>
        <dd>
            @Html.DisplayFor(model => model.description)
        </dd>

        <dt>
            Chi nhánh xuất
        </dt>
        <dd>
            @Html.DisplayFor(model => model.branchFrom.branchName)
        </dd>

        <dt>
            Kho xuất
        </dt>
        <dd>
            @Html.DisplayFor(model => model.warehouseFrom.warehouseName)
        </dd>

        <dt>
            Chi nhánh nhận
        </dt>
        <dd>
            @Html.DisplayFor(model => model.branchTo.branchName)
        </dd>

        <dt>
            Kho nhận
        </dt>
        <dd>
            @Html.DisplayFor(model => model.warehouseTo.warehouseName)
        </dd>

        <dt>
            Ngày tạo
        </dt>
        <dd>
            @Html.DisplayFor(model => model.createdAt)
        </dd>

        <dt>
            Phiếu điều chuyển liên quan
        </dt>
        <dd>
            @Html.DisplayFor(model => model.transferOrder.transferOrderNumber)
        </dd>
    </dl>


</div>

