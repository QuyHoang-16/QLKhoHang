@model QuanLyKho.Models.Invent.TransferOut


@{
    ViewData["Title"] = "Tạo mới phiếu xuất điều chuyển";
    Layout = "~/Views/Shared/_AdminlteNetcoreCreate.cshtml";
    ViewData["EntityIcon"] = "fa fa-upload";
    ViewData["HeaderText"] = "Tạo mới phiếu xuất điều chuyển";
    ViewData["CreateInfo"] = "Xuất kho hoặc xuất điều chuyển, chỉ có thể xử lý các Lệnh điều chuyển [Mở] chưa được xử lý xuất hoặc nhập kho. Lệnh điều chuyển đã xử lý sẽ không hiển thị trong danh sách chọn.";
}

<partial name="_StatusMessage" model="@ViewBag.StatusMessage" />
<div class="row">
    <div class="col-md-12">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label for="transferOutNumber">Mã phiếu xuất điều chuyển</label>
                    <input asp-for="transferOutNumber" class="form-control" />
                    <span asp-validation-for="transferOutNumber" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="transferOutDate">Ngày xuất kho</label>
                    <div class="input-group date">
                        <div class="input-group-addon">
                            <i class="fa fa-calendar"></i>
                        </div>
                        <input asp-for="transferOutDate" value="@Model.transferOutDate.ToString("MM/dd/yyyy")" class="form-control pull-right datepicker" type="text" />
                    </div>
                    <span asp-validation-for="transferOutDate" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="transferOrderId">Phiếu điều chuyển</label>
                    <select asp-for="transferOrderId" class="form-control select2" asp-items="ViewBag.transferOrderId"></select>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="description">Ghi chú</label>
            <input asp-for="description" class="form-control" />
            <span asp-validation-for="description" class="text-danger"></span>
        </div>

        <!-- Ẩn theo logic hệ thống -->
        <div class="row hidden">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="branchIdFrom">Chi nhánh xuất</label>
                    <select asp-for="branchIdFrom" class="form-control select2" asp-items="ViewBag.branchIdFrom"></select>
                    <span asp-validation-for="branchIdFrom" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="branchIdTo">Chi nhánh nhận</label>
                    <select asp-for="branchIdTo" class="form-control select2" asp-items="ViewBag.branchIdTo"></select>
                    <span asp-validation-for="branchIdTo" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Warehouse ẩn / disable -->
        <div class="row hidden">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="warehouseIdFrom">Kho xuất</label>
                    <select disabled asp-for="warehouseIdFrom" class="form-control select2" asp-items="ViewBag.warehouseIdFrom"></select>
                    <span asp-validation-for="warehouseIdFrom" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="warehouseIdTo">Kho nhận</label>
                    <select disabled asp-for="warehouseIdTo" class="form-control select2" asp-items="ViewBag.warehouseIdTo"></select>
                    <span asp-validation-for="warehouseIdTo" class="text-danger"></span>
                </div>
            </div>
        </div>

    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

