@using QuanLyKho.Models.Invent
@inject QuanLyKho.Data.ApplicationDbContext Context

@{
    var stocks = new[]
{
    new { Product = "P-001", QtyPo = 100, QtyReceiving = 100, QtySo = 50, QtyShipment = 30, QtyOnhand = 70 },
    new { Product = "P-002", QtyPo = 200, QtyReceiving = 150, QtySo = 120, QtyShipment = 80, QtyOnhand = 70 },
    new { Product = "P-003", QtyPo = 300, QtyReceiving = 250, QtySo = 200, QtyShipment = 150, QtyOnhand = 100 }
};

    int po = Context.PurchaseOrders.Count();
    int so = Context.SalesOrders.Count();
    int shipment = Context.Shipments.Count();
    int receive = Context.Receivings.Count();
}

<div class="content-wrapper">
    <section class="content">
        <div class="home-dashboard">
            <!-- DASHBOARD CARDS -->
            <div class="row">

                <div class="col-lg-3 col-xs-6">
                    <div class="dashboard-card bg-blue">
                        <div>
                            <h2>@po</h2>
                            <p>Đơn mua hàng</p>
                        </div>
                        <i class="fa fa-file-text"></i>
                    </div>
                </div>

                <div class="col-lg-3 col-xs-6">
                    <div class="dashboard-card bg-green">
                        <div>
                            <h2>@so</h2>
                            <p>Đơn bán hàng</p>
                        </div>
                        <i class="fa fa-cart-plus"></i>
                    </div>
                </div>

                <div class="clearfix visible-xs-block"></div>

                <div class="col-lg-3 col-xs-6">
                    <div class="dashboard-card bg-orange">
                        <div>
                            <h2>@receive</h2>
                            <p>Nhập hàng</p>
                        </div>
                        <i class="fa fa-truck"></i>
                    </div>
                </div>

                <div class="col-lg-3 col-xs-6">
                    <div class="dashboard-card bg-red">
                        <div>
                            <h2>@shipment</h2>
                            <p>Giao hàng</p>
                        </div>
                        <i class="fa fa-plane"></i>
                    </div>
                </div>

            </div>



            <!-- TABLE -->
            <div class="card-box">
                <div class="card-header">
                    <h3>📦 Tồn kho theo thời gian thực</h3>
                    <input type="text" id="mainSearch" placeholder="🔍 Tìm kiếm...">
                </div>

                <div class="table-responsive">
                    <table class="table custom-table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>SL mua</th>
                                <th>SL nhập</th>
                                <th>SL bán</th>
                                <th>SL giao</th>
                                <th>Tồn kho</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in stocks)
                            {
                                <tr>
                                    <td><b>@item.Product</b></td>
                                    <td>@item.QtyPo</td>
                                    <td>@item.QtyReceiving</td>
                                    <td>@item.QtySo</td>
                                    <td>@item.QtyShipment</td>
                                    <td>
                                        <span class="badge-stock">@item.QtyOnhand</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>
