@model QuanLyKho.Models.Invent.Branch
@inject QuanLyKho.Data.ApplicationDbContext _context;
@{
    ViewData["Title"] = "Xóa";
    Layout = "~/Views/Shared/_AdminlteNetcoreDelete.cshtml";
    ViewData["EntityIcon"] = "fa fa-building-o";
    ViewData["DeleteInfo"] = "Chi nhánh đã có kho trực thuộc thì không thể xóa.";
    QuanLyKho.Models.Invent.Warehouse wh = _context.Warehouses.Where(x => x.branchId.Equals(Model.branchId)).FirstOrDefault();
    ViewData["IsCanDeleted"] = false;
    if (wh == null)
    {
        ViewData["IsCanDeleted"] = true;
    }
}


@Html.Partial("_StatusMessage", (string)ViewBag.StatusMessage)
<div>
    @if (ViewData["IsCanDeleted"] is bool canDeleted && !canDeleted)
    {
        <div class="callout callout-warning" style="margin-bottom: 15px;">
            <h4><i class="fa fa-warning"></i> Không thể xóa</h4>
            <p>@ViewData["DeleteInfo"]</p>
        </div>
    }

    @{
        var addressParts = new List<string>();
        if (!string.IsNullOrWhiteSpace(Model.street1)) { addressParts.Add(Model.street1); }
        if (!string.IsNullOrWhiteSpace(Model.street2)) { addressParts.Add(Model.street2); }
        if (!string.IsNullOrWhiteSpace(Model.city)) { addressParts.Add(Model.city); }
        if (!string.IsNullOrWhiteSpace(Model.province)) { addressParts.Add(Model.province); }
        if (!string.IsNullOrWhiteSpace(Model.country)) { addressParts.Add(Model.country); }
        var addressText = string.Join(", ", addressParts);
    }

    <table class="table table-striped">
        <tbody>
            <tr>
                <th style="width: 180px;">Tên chi nhánh</th>
                <td>
                    <strong>@Html.DisplayFor(m => m.branchName)</strong>
                    @if (Model.isDefaultBranch)
                    {
                        <span class="label label-success" style="margin-left: 6px;">Mặc định</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Mô tả</th>
                <td>
                    @if (!string.IsNullOrWhiteSpace(Model.description))
                    {
                        @Html.DisplayFor(m => m.description)
                    }
                    else
                    {
                        <span class="text-muted">Chưa cập nhật</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Địa chỉ</th>
                <td>
                    @if (!string.IsNullOrWhiteSpace(addressText))
                    {
                        <i class="fa fa-map-marker text-red"></i> @addressText
                    }
                    else
                    {
                        <span class="text-muted">Chưa cập nhật</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Ngày tạo</th>
                <td>@Model.createdAt.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        </tbody>
    </table>

</div>

