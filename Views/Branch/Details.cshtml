@model QuanLyKho.Models.Invent.Branch

@{
    ViewData["Title"] = "Chi tiết";
    Layout = "~/Views/Shared/_AdminlteNetcoreDetails.cshtml";
    ViewData["EntityIcon"] = "fa fa-building-o";
}

<div class="row">
    <div class="col-md-9">
        <div class="box box-primary">
            <div class="box-header with-border">
                <h3 class="box-title">
                    <i class="fa fa-building-o text-primary"></i>
                    @Html.DisplayFor(m => m.branchName)
                </h3>
                @if (Model.isDefaultBranch)
                {
                    <span class="label label-success pull-right">Mặc định</span>
                }
            </div>
            <div class="box-body">
                @{
                    var addressParts = new List<string>();
                    if (!string.IsNullOrWhiteSpace(Model.street1)) { addressParts.Add(Model.street1); }
                    if (!string.IsNullOrWhiteSpace(Model.street2)) { addressParts.Add(Model.street2); }
                    if (!string.IsNullOrWhiteSpace(Model.city)) { addressParts.Add(Model.city); }
                    if (!string.IsNullOrWhiteSpace(Model.province)) { addressParts.Add(Model.province); }
                    if (!string.IsNullOrWhiteSpace(Model.country)) { addressParts.Add(Model.country); }
                    var addressText = string.Join(", ", addressParts);
                }

                <table class="table table-striped">
                    <tbody>
                        <tr>
                            <th style="width: 180px;">Mô tả</th>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(Model.description))
                                {
                                    @Html.DisplayFor(m => m.description)
                                }
                                else
                                {
                                    <span class="text-muted">Chưa cập nhật</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Địa chỉ</th>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(addressText))
                                {
                                    <i class="fa fa-map-marker text-red"></i> @addressText
                                }
                                else
                                {
                                    <span class="text-muted">Chưa cập nhật</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Ngày tạo</th>
                            <td>@Model.createdAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="box-footer">
                <div class="form-group">
                    <a asp-action="Edit" asp-route-id="@Model.branchId" class="btn btn-primary">Sửa</a>
                    <a asp-action="Index" class="btn btn-default">Trở lại danh sách</a>
                </div>
            </div>

        </div>
    </div>
    <div class="col-md-3"></div>
</div>
