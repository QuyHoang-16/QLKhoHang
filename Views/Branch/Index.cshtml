@model IEnumerable<QuanLyKho.Models.Invent.Branch>

@{
    ViewData["Title"] = "Danh sách";
    Layout = "~/Views/Shared/_AdminlteNetcoreIndex.cshtml";
    ViewData["EntityIcon"] = "fa fa-building";
    ViewData["ListTitle"] = "Danh sách chi nhánh";
    ViewData["ButtonAddText"] = "Chi Nhánh";

}


<table class="table table-hover table-striped" style="width:100%">
    <thead>
        <tr>
            <th style="width: 110px;">Thao tác</th>
            <th>Chi nhánh</th>
            <th>Địa chỉ</th>
            <th style="width: 140px;">Ngày tạo</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var addressParts = new List<string>();
            if (!string.IsNullOrWhiteSpace(item.street1)) { addressParts.Add(item.street1); }
            if (!string.IsNullOrWhiteSpace(item.street2)) { addressParts.Add(item.street2); }
            if (!string.IsNullOrWhiteSpace(item.city)) { addressParts.Add(item.city); }
            if (!string.IsNullOrWhiteSpace(item.province)) { addressParts.Add(item.province); }
            if (!string.IsNullOrWhiteSpace(item.country)) { addressParts.Add(item.country); }
            var addressText = string.Join(", ", addressParts);
        <tr>
            <td>
                <div class="tools">
                    <a asp-action="Edit" asp-route-id="@item.branchId" class="btn btn-primary btn-xs" title="Sửa"><i class="fa fa-pencil"></i></a>
                    <a asp-action="Details" asp-route-id="@item.branchId" class="btn btn-info btn-xs" title="Chi tiết"><i class="fa fa-eye"></i></a>
                    <a asp-action="Delete" asp-route-id="@item.branchId" class="btn btn-danger btn-xs" title="Xóa"><i class="fa fa-trash"></i></a>
                </div>
                
            </td>
            <td>
                <div>
                    <strong>@Html.DisplayFor(modelItem => item.branchName)</strong>
                    @if (item.isDefaultBranch)
                    {
                        <span class="label label-success" style="margin-left: 6px;">Mặc định</span>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(item.description))
                {
                    <div class="text-muted" style="margin-top: 2px;">@Html.DisplayFor(modelItem => item.description)</div>
                }
            </td>
            <td>
                @if (!string.IsNullOrWhiteSpace(addressText))
                {
                    <span><i class="fa fa-map-marker text-red"></i> @addressText</span>
                }
                else
                {
                    <span class="text-muted">Chưa cập nhật</span>
                }
            </td>
            <td>
                @item.createdAt.ToString("dd/MM/yyyy")
            </td>

        </tr>
        }
    </tbody>
</table>

